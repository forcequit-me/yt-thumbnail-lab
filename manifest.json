{
  "manifest_version": 3,
  "name": "YT Thumbnail Lab",
  "version": "1.3.0",
  "description": "Preview your YouTube thumbnails inside the real YouTube UI, and turn every thumbnail grayscale to study composition without color.",
  "permissions": ["storage", "contextMenus", "unlimitedStorage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-ytlab": {
      "suggested_key": { "default": "Alt+Shift+B" },
      "description": "Toggle B\u0026W on/off"
    },
    "toggle-sim": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Toggle Simulator on/off"
    }
  }
}
